{
  "buildCommand": "cd frontend && pnpm install && pnpm build",
  "outputDirectory": "frontend/.next",
  "installCommand": "cd frontend && pnpm install",
  "framework": "nextjs",
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "http://localhost:3001/api/:path*"
    }
  ],
  "env": {
    "NEXT_PUBLIC_API_URL": "@arc_api_url",
    "NEXT_PUBLIC_CHAIN_ID": "@arc_chain_id",
    "NEXT_PUBLIC_RPC_URL": "@arc_rpc_url",
    "NEXT_PUBLIC_APP_URL": "@arc_app_url"
  }
}
